<!-- navbar -->

---
---
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@700&display=swap" rel="stylesheet">

<header>
<nav class="sticky top-0 z-50 w-full bg-[#F5F2E9]/95 backdrop-blur-md shadow-sm" aria-label="Hovednavigation">
  <div class="max-w-[1300px] mx-auto px-6">
    <div class="flex items-center justify-between py-4">

      <!-- Logo (left) -->
      <a href="/" class="flex items-center" aria-label="Forside">
        <img src="/logo.png" alt="Forside — Coffeenhagen" class="w-20 h-20 object-contain" loading="eager" />
      </a>

      <!-- Toggle (hidden checkbox) + centered nav -->
      <div class="flex-1 flex justify-center items-center relative">
        <input id="nav-toggle" type="checkbox" class="hidden peer" />

        <!-- Mobile burger button -->
        <label for="nav-toggle" class="md:hidden inline-flex items-center justify-center p-2 rounded-md cursor-pointer" aria-label="Åbn menu" aria-controls="main-navigation">
          <!-- Hamburger -->
          <svg class="w-6 h-6 text-[#372115] block peer-checked:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <!-- Luk hamburger menu -->
          <svg class="w-6 h-6 text-[#372115] hidden peer-checked:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </label>

        <!-- Navigation -->
        <ul
          id="main-navigation"
          role="menubar"
          aria-label="Primær navigation"
          class="hidden peer-checked:flex md:flex flex-col md:flex-row items-center gap-6 text-center
                 w-full md:w-auto justify-center absolute left-0 right-0 top-full md:static mt-2 md:mt-0 z-40
                 bg-[#F5F2E9] md:bg-transparent p-4 md:p-0 rounded-md md:rounded-none shadow-md md:shadow-none
                 [font-family:'Manrope',sans-serif] text-[18px] md:text-[20px] font-bold text-[#372115]"
        >
          <li><a href="/menu" class="block px-3 py-2 md:px-2 md:pb-1 border-b-2 border-transparent hover:text-[#372115]/75 hover:border-[#372115]/80">Menu</a></li>
           
          <li><a href="/om-os" class="block px-3 py-2 md:px-2 md:pb-1 border-b-2 border-transparent hover:text-[#372115]/75 hover:border-[#372115]/80">Om os</a></li>

          <li><a href="/event" class="block px-3 py-2 md:px-2 md:pb-1 border-b-2 border-transparent hover:text-[#372115]/75 hover:border-[#372115]/80">Hold event hos os</a></li>
          
          <li><a href="/find-os" class="block px-3 py-2 md:px-2 md:pb-1 border-b-2 border-transparent hover:text-[#372115]/75 hover:border-[#372115]/80">Find os</a></li>
         
          <li><a href="/kontakt" class="block px-3 py-2 md:px-2 md:pb-1 border-b-2 border-transparent hover:text-[#372115]/75 hover:border-[#372115]/80">Kontakt</a></li>

          <!-- Mobil grøn-CTA inde i menu -->
          <li class="md:hidden mt-2">
            <a href="/formular-book" role="button" class="inline-flex w-full justify-center px-4 py-2 rounded-lg bg-[#2e432e] text-[#F5F2E9] font-bold hover:opacity-75 [font-family:'Manrope',sans-serif]">Book bord</a>
          </li>
        </ul>
      </div>

      <!-- Desktop Grøn CTA + spacer -->
      <div class="flex items-center">
        <a
          href="/formular-book"
          role="button"
          aria-label="Book bord"
          class="hidden md:inline-flex ml-4 w-[130px] h-[50px] rounded-[10px] bg-[#2e432e] text-[#F5F2E9] items-center justify-center
                 px-[10px] py-[10px] font-bold transition-all duration-150 ease-in-out focus:outline-none
                 [box-shadow:3px_3px_5px_rgba(55,33,21,0.5)]
                 hover:opacity-75 [font-family:'Manrope',sans-serif]"
        >
          Book bord
        </a>

        <div class="hidden md:block w-12" aria-hidden="true"></div>
      </div>
    </div>
  </div>
  </header>