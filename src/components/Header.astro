<!-- navbar -->

---
---
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@700&display=swap" rel="stylesheet">

<nav class="w-full bg-transparent" aria-label="Hovednavigation">
  <div class="w-full px-6">
    <div class="flex items-center justify-between py-4 max-w-[1300px] mx-auto">
      <!-- Logo (PNG) links to frontpage and logo size-->
      <a href="/" class="flex items-center" aria-label="Forside">
        <img src="/logo.png" alt="Forside — Coffeenhagen" class="w-20 h-20 object-contain" loading="eager" />
      </a>

      <!-- Centered navigation (stretches) -->
      <div class="flex-1 flex justify-center">
        <input id="nav-toggle" type="checkbox" class="hidden peer" />

        <ul
          id="main-navigation"
          role="menubar"
          aria-label="Primær navigation"
          class="hidden peer-checked:flex md:flex flex-col md:flex-row items-center gap-8 text-center
                 w-full md:w-auto justify-center absolute left-0 right-0 md:static top-full md:top-auto mt-2 md:mt-0 z-50
                 [font-family:'Manrope',sans-serif] text-[20px] font-bold text-[#372115]"
        >
          <li>
            <a href="/menu" class="px-2 pb-1 border-b-2 border-transparent transition-colors duration-150 hover:text-[#372115]/75 hover:border-[#372115]/75">
              Menu
            </a>
          </li>
          <li>
            <a href="/about" class="px-2 pb-1 border-b-2 border-transparent transition-colors duration-150 hover:text-[#372115]/75 hover:border-[#372115]/75">
              Om os
            </a>
          </li>
          <li>
            <a href="/contact" class="px-2 pb-1 border-b-2 border-transparent transition-colors duration-150 hover:text-[#372115]/75 hover:border-[#372115]/75">
              Kontakt
            </a>
          </li>
          <li>
            <a href="/find" class="px-2 pb-1 border-b-2 border-transparent transition-colors duration-150 hover:text-[#372115]/75 hover:border-[#372115]/75">
              Find os
            </a>
          </li>
        </ul>
      </div>

      <!-- Mobile toggle / spacer -->
      <div class="flex items-center">
        <label for="nav-toggle" class="md:hidden inline-flex items-center justify-center p-2 rounded-md cursor-pointer" aria-label="Åbn menu">
          <svg class="w-6 h-6 text-[#372115]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </label>

        <!-- Grøn CTA-Button placed on the right side (visible on md+). margin matches spacer width for even alignment -->
        <button
          class="hidden md:inline-flex ml-4 w-[130px] h-[50px] rounded-[10px] bg-[#2e432e] text-white items-center justify-center
                 px-[10px] py-[10px] font-bold transition-all duration-150 ease-in-out focus:outline-none
                 [box-shadow:3px_3px_5px_rgba(55,33,21,0.5)]
                 hover:opacity-75 hover:[box-shadow:inset_0px_4px_10px_rgba(0,0,0,0.25),_3px_3px_5px_rgba(55,33,21,0.5)]
                 [font-family:'Manrope',sans-serif]"
        >
          Book bord
        </button>

        <!-- spacer (keeps right area same width as logo on larger screens) -->
        <div class="hidden md:block w-12"></div>
      </div>
       
     
    </div>
  </div>
</nav>
