---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="event">  

 <!-- SECTION 1 med animate fade af tekst og billede-->
<section class="py-20">
  <div class="text-left intersect:animate-fade-right intersect:duration-9000">

    <div class="mx-auto flex max-w-[1200px] flex-col items-start gap-12 px-6 md:flex-row">

      <!-- TEXT -->
      <div class="flex-1 text-[#372115] [font-family:'Manrope',sans-serif]">

        <h2 class="text-3xl mt-20 font-normal leading-tight md:text-5xl">
          Hold dit event hos os!
        </h2>

        <p class="mt-20 max-w-prose text-base leading-[1.8]">
          Kunne du tænke dig at holde din fødselsdag, barnedåb eller andet i vores lækre lokaler? Så er du kommet til det rette sted!
        </p>

        <p class="mt-6 max-w-prose text-base leading-[1.8]">
          Hele caféen står til rådighed ved afholdelse af dit event, kun til dig og dine gæster.
        </p>

        <p class="mt-6 max-w-prose text-base leading-[1.8]">
          Lyder det som noget for dig? Så kom forbi caféen, så vi kan få os en snak, eller skriv eller ring til os på
        </p>

        <p class="mt-6 max-w-prose font-bold leading-[1.8]">
          +45 51 88 58 25
        </p>

        <p class="mt-2 max-w-prose font-bold leading-[1.8]">
          info@coffeenhagen.dk
        </p>

      </div>

      <!-- billede af event -->
      <div class="flex flex-1 justify-center">
        <img
          src="/event.png"
          alt="event"
          class="w-full max-w-[500px] mb-20 rounded-sm shadow-lg"
        />
      </div>

    </div>
  </div>
<div class="[font-family:'Manrope',sans-serif] mb-10 flex justify-center">
       <p class="mt-6 font-bold max-w-prose leading-[1.8]">
          Se billeder fra events her
        </p>
      </div>

  <!-- 10 billeder og animation-->
  <div
    class="text-left intersect:animate-fade-up intersect:duration-9000"  >
    <section class="pb-20">
      <div
        class="mx-auto grid max-w-[1200px] grid-cols-2 gap-4 px-6 md:grid-cols-5"
      >
        <img src="/event1.png" alt="event 1" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event2.png" alt="event 2" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event3.png" alt="event 3" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event4.png" alt="event 4" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event5.png" alt="event 5" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event6.png" alt="event 6" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event7.png" alt="event 7" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event8.png" alt="event 8" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event9.png" alt="event 9" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
        <img src="/event10.png" alt="event 10" class="h-40 w-full rounded-sm object-cover shadow-md md:h-60" />
      </div>
    </section>
</section>